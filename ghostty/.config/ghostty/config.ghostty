# Font configuration
font-family = JetBrainsMono Nerd Font Propo
font-size = 14

# Window settings
window-padding-x = 14
window-padding-y = 14
window-decoration = false
background-opacity = 0.98

# Terminal settings
term = xterm-256color

# Keybindings
keybind = f11=toggle_fullscreen

# Theme
#theme = TokyoNight
#theme = iTerm2 Smoooooth
#theme = iTerm2 Default
theme = Kitty Default
