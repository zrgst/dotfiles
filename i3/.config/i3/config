# i3 config

set $mod Mod4

# Font
font pango:JetBrainsMono Nerd Font 14

# Mouse + floating drag
floating_modifier $mod

# -----------------------------
# APPS / LAUNCHERS
# -----------------------------

# Terminal
bindsym $mod+Return exec wezterm

# Firefox
bindsym $mod+Shift+b exec firefox

# dmenu
bindsym $mod+p exec --no-startup-id dmenu_run

# Flameshot
bindsym $mod+Shift+s exec --no-startup-id flameshot gui

# -----------------------------
# SCRATCHPADS
# -----------------------------

# Regler
for_window [title="^scratchpad-term$"] floating enable, resize set 50 ppt 50 ppt, move position center, move scratchpad
for_window [title="^scratchpad-music$"] floating enable, resize set 50 ppt 50 ppt, move position center, move scratchpad
for_window [title="^scratchpad-alsa$"] floating enable, resize set 50 ppt 50 ppt, move position center, move scratchpad

# Vis eksisterende scratchpads
bindsym $mod+Home [title="^scratchpad-term$"] scratchpad show
bindsym $mod+m [title="^scratchpad-music$"] scratchpad show
bindsym $mod+XF86AudioMute [title="^scratchpad-alsa$"] scratchpad show

# Start scratchpads
bindsym $mod+Shift+Home exec --no-startup-id kitty --title scratchpad-term
bindsym $mod+Shift+m exec --no-startup-id kitty --title scratchpad-music ncmpcpp
bindsym $mod+Shift+XF86AudioMute exec --no-startup-id kitty --title scratchpad-alsa alsamixer

# -----------------------------
# WINDOW MANAGEMENT
# -----------------------------

# Kill focused window
bindsym $mod+w kill

# Focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Split / layout
bindsym $mod+v split v
bindsym $mod+b split h
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+e layout toggle split

# Floating
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Parent focus
bindsym $mod+a focus parent

# Resize direkte uten å gå inn i resize-mode
bindsym $mod+Ctrl+h resize shrink width 10 px or 10 ppt
bindsym $mod+Ctrl+l resize grow width 10 px or 10 ppt
bindsym $mod+Ctrl+j resize grow height 10 px or 10 ppt
bindsym $mod+Ctrl+k resize shrink height 20 px or 10 ppt

# Toggle bar
#bindsym $mod+b bar mode toggle

# -----------------------------
# WORKSPACES
# -----------------------------

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9:󰓓 "
set $ws10 "10"

# Go to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Send focused window to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# -----------------------------
# I3 CONTROL
# -----------------------------

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'"

# -----------------------------
# BORDERS / GAPS
# -----------------------------

default_border pixel 2
default_floating_border pixel 2
new_window pixel 2
new_float pixel 2

gaps inner 10
gaps outer 5
smart_gaps on
hide_edge_borders smart

# -----------------------------
# RESIZE MODE
# -----------------------------

mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

# -----------------------------
# MEDIA KEYS
# -----------------------------

set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# -----------------------------
# AUTOSTART
# -----------------------------

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id feh --randomize --bg-fill ~/Pictures/wallpapers/*
exec --no-startup-id dunst
exec --no-startup-id mpd
exec --no-startup-id mpc
exec --no-startup-id flameshot
exec --no-startup-id xrandr --output DP-0 --mode 2560x1440 --rate 120 --primary
exec --no-startup-id dbus-update-activation-environment --systemd --all
exec --no-startup-id /usr/lib/mate-polkit/polkit-mate-authentication-agent-1
exec_always --no-startup-id pkill picom; picom --config ~/.config/picom/picom.conf

# -----------------------------
# BAR
# -----------------------------

bar {
    position top
    status_command i3status-rs ~/.config/i3status-rust/config.toml
    font pango:JetBrainsMono Nerd Font 14
    tray_output primary
    mode dock

    colors {
        separator         #565f89
        background        #1a1b26
        statusline        #c0caf5

        focused_workspace #7aa2f7 #7aa2f7 #1a1b26
        active_workspace  #24283b #24283b #c0caf5
        inactive_workspace #1a1b26 #1a1b26 #565f89
        urgent_workspace  #f7768e #f7768e #1a1b26
    }
}
