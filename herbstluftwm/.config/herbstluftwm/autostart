#!/usr/bin/env bash

hc() { herbstclient "$@"; }

Mod=Mod4

# --------------------------------------------------
# Reset
# --------------------------------------------------
hc keyunbind --all
hc mouseunbind --all
hc unrule -F

# --------------------------------------------------
# Tags / workspaces
# --------------------------------------------------
hc rename default 1
hc keybind "$Mod-1" use 1
hc keybind "$Mod-Shift-1" move 1

for i in {2..9}; do
    hc add "$i"
    hc keybind "$Mod-$i" use "$i"
    hc keybind "$Mod-Shift-$i" move "$i"
done

# --------------------------------------------------
# Theme / appearance
# --------------------------------------------------

# Tokyo Night colors (kun de som faktisk er i bruk)
border_inactive="#414868"
border_active="#7aa2f7"
border_urgent="#f7768e"

# Gaps / frame
hc set frame_gap 0
hc set window_gap 6
hc set frame_border_width 1
hc set always_show_frame 1
hc set frame_transparent_width 0
hc set frame_bg_transparent 1
hc set show_frame_decorations none

# Frame colors
hc set frame_bg_normal "$border_inactive"
hc set frame_bg_active "$border_active"
hc set frame_border_normal_color "$border_inactive"
hc set frame_border_active_color "$border_active"
hc set urgent_color "$border_urgent"

# Client borders
hc attr theme.tiling.active.border_width 2
hc attr theme.tiling.normal.border_width 1
hc attr theme.tiling.urgent.border_width 0
hc attr theme.floating.active.border_width 2
hc attr theme.floating.normal.border_width 1
hc attr theme.floating.urgent.border_width 0

# Hide client titles
hc attr theme.tiling.active.title_when never
hc attr theme.tiling.normal.title_when never
hc attr theme.tiling.urgent.title_when never
hc attr theme.floating.active.title_when never
hc attr theme.floating.normal.title_when never
hc attr theme.floating.urgent.title_when never

# Default layout
hc set layout horizontal

# --------------------------------------------------
# Focus / movement
# --------------------------------------------------
hc keybind "$Mod-h" focus left
hc keybind "$Mod-j" focus down
hc keybind "$Mod-k" focus up
hc keybind "$Mod-l" focus right

hc keybind "$Mod-Shift-h" shift left
hc keybind "$Mod-Shift-j" shift down
hc keybind "$Mod-Shift-k" shift up
hc keybind "$Mod-Shift-l" shift right

# --------------------------------------------------
# Layout / resize
# --------------------------------------------------
hc keybind "$Mod-v" split right 0.5
hc keybind "$Mod-b" split bottom 0.5
hc keybind "$Mod-q" remove
hc keybind "$Mod-f" fullscreen toggle
hc keybind "$Mod-Shift-space" floating toggle

hc keybind "$Mod-Control-h" resize left +0.05
hc keybind "$Mod-Control-l" resize right +0.05

# Promote focused client to "master" / left frame
hc keybind "$Mod-Shift-Return" chain , move left , focus left

# --------------------------------------------------
# Launch / control
# --------------------------------------------------
hc keybind "$Mod-Return" spawn kitty
hc keybind "$Mod-p" spawn j4-dmenu-desktop
hc keybind "$Mod-Shift-p" spawn zrgst_system_menu
hc keybind "$Mod-Escape" spawn powermenu

hc keybind "$Mod-w" close
hc keybind "$Mod-Shift-q" quit
hc keybind "$Mod-Shift-r" reload

hc keybind "$Mod-Tab" cycle_all +1
hc keybind "$Mod-Shift-Tab" cycle_all -1

hc keybind "$Mod-Shift-s" spawn flameshot gui

# Gaps toggle
hc keybind "$Mod-g" chain , set frame_gap 0 , set window_gap 0
hc keybind "$Mod-Shift-g" chain , set frame_gap 6 , set window_gap 6

# Scratchpad
hc keybind "$Mod-Home" spawn ~/.local/bin/toggle-scratchpad-kitty
hc keybind "$Mod-Shift-Home" spawn ~/.local/bin/start-scratchpad-kitty

# --------------------------------------------------
# Mouse
# --------------------------------------------------
hc mousebind "$Mod-Button1" move
hc mousebind "$Mod-Button2" resize

# --------------------------------------------------
# Rules
# --------------------------------------------------
hc rule class=scratchpad-kitty \
    floating=on \
    floatplacement=none \

# --------------------------------------------------
# Autostart programs
# --------------------------------------------------
feh --randomize --bg-fill ~/Pictures/wallpapers/* &

xset s 0 0
xset s off
xset -dpms
xset s noblank

pgrep -x dunst >/dev/null || dunst &
pgrep -x flameshot >/dev/null || flameshot &
pgrep -x mpd >/dev/null || mpd &

pkill picom 2>/dev/null
picom -b &

~/.config/polybar/launch.sh &
